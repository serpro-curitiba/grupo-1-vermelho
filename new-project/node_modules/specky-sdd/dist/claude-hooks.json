{
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/session-banner.sh",
          "timeout": 5
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/pipeline-guard.sh",
          "timeout": 5
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "mcp__specky__sdd_init|mcp__specky__sdd_create_branch",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_discover|mcp__specky__sdd_research|mcp__specky__sdd_import_document|mcp__specky__sdd_import_transcript|mcp__specky__sdd_batch_import",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_write_spec|mcp__specky__sdd_turnkey_spec|mcp__specky__sdd_figma_to_spec",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_write_design|mcp__specky__sdd_generate_all_diagrams",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_write_tasks|mcp__specky__sdd_checklist",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_implement|mcp__specky__sdd_generate_tests|mcp__specky__sdd_generate_pbt",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_verify_tests|mcp__specky__sdd_verify_tasks|mcp__specky__sdd_check_sync",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_run_analysis|mcp__specky__sdd_cross_analyze|mcp__specky__sdd_compliance_check",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_create_pr|mcp__specky__sdd_export_work_items",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/artifact-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/security-scan.sh",
          "timeout": 30
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/release-gate.sh",
          "timeout": 15
        }
      ]
    },
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/branch-validator.sh",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "mcp__specky__sdd_init",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/phase-gate.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/auto-checkpoint.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_write_spec|mcp__specky__sdd_turnkey_spec|mcp__specky__sdd_figma_to_spec",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/phase-gate.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/spec-quality.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/ears-validator.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/lgtm-gate.sh",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/spec-sync.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/auto-checkpoint.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_write_design|mcp__specky__sdd_generate_all_diagrams",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/phase-gate.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/spec-sync.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/lgtm-gate.sh",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/auto-checkpoint.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_write_tasks|mcp__specky__sdd_checklist",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/phase-gate.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/task-tracer.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/lgtm-gate.sh",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/spec-sync.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/auto-checkpoint.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_import_document|mcp__specky__sdd_import_transcript|mcp__specky__sdd_batch_import",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/auto-checkpoint.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_implement|mcp__specky__sdd_generate_tests|mcp__specky__sdd_generate_pbt",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/spec-sync.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/auto-checkpoint.sh",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_verify_tests|mcp__specky__sdd_verify_tasks",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/phase-gate.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/drift-monitor.sh",
          "timeout": 10
        }
      ]
    },
    {
      "matcher": "mcp__specky__sdd_run_analysis|mcp__specky__sdd_cross_analyze|mcp__specky__sdd_compliance_check",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/phase-gate.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/cognitive-debt-alert.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/metrics-dashboard.sh",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/drift-monitor.sh",
          "timeout": 10
        }
      ]
    },
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/spec-sync.sh",
          "timeout": 10
        },
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/auto-checkpoint.sh",
          "timeout": 5
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash .claude/hooks/scripts/security-scan.sh",
          "timeout": 30
        }
      ]
    }
  ]
}
