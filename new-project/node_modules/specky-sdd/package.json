{
  "name": "specky-sdd",
  "version": "3.4.0-rc.14",
  "description": "Specky — Spec-Driven Development engine. 57 MCP tools, 13 agents, 22 prompts, 8 skills, 16 hooks. Unified `specky` CLI installs to Claude Code and GitHub Copilot on macOS, Linux, and Windows.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "specky": "dist/cli/index.js",
    "specky-sdd": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/templates && cp -r templates dist/templates && node scripts/build-claude-hooks.mjs && node scripts/finalize-build.mjs",
    "start": "node dist/cli/index.js serve",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "node scripts/release.mjs"
  },
  "icon": "media/specky-icon-256.png",
  "files": [
    "dist/",
    ".apm/",
    ".claude-plugin/",
    "templates/",
    "apm.yml",
    "config.yml",
    "media/specky-icon-256.png",
    "media/specky-icon-128.png",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "spec-driven-development",
    "sdd",
    "ears-notation",
    "requirements",
    "specification",
    "copilot",
    "claude",
    "ai-agent"
  ],
  "author": "Paula Silva <paulasilvatech@github.com> (https://github.com/paulasilvatech)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulasilvatech/specky.git"
  },
  "homepage": "https://github.com/paulasilvatech/specky#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
